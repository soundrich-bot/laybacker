{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Laybacker",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "core:window:allow-set-focus",
    "core:event:default",
    "updater:default",
    "process:default"
  ]
}
