{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Laybacker",
  "version": "0.1.21",
  "identifier": "com.laybacker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LAYBACKER",
        "width": 960,
        "height": 800,
        "minWidth": 800,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/LaybackComplete.wav", "binaries/FFMPEG_LICENSE.txt"],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "category": "Utility",
    "shortDescription": "Replace audio on video files. Fast.",
    "longDescription": "Laybacker is a tool for sound post-production professionals. Drag video and audio files, match them up, normalize loudness, and export. Simple.",
    "copyright": "2026 Soundrich Ltd.",
    "license": "GPL-3.0"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/soundrich-bot/laybacker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1OTk5MUJEMzk0RjMzQjAKUldTd00wODV2WkdaRlVjNzBFYTBPUGZkWlIwQlo4eDFxQ1l1dTNMVjdiVml4QnkxcGIzZVRIclQK"
    }
  }
}
